# =============================================================================
# .gitignore — Arc Framework Project
# Place at the project root (same directory as arc.toml).
# =============================================================================


# -----------------------------------------------------------------------------
# Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
*.enc
secrets/
*.key
*.pem
*.p12


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover
coverage.xml
*.lcov

# Type checkers
.mypy_cache/
.dmypy.json
.pytype/
.pyre/
pyrightconfig.json


# -----------------------------------------------------------------------------
# Arc runtime
# -----------------------------------------------------------------------------
# Backups contain data — do NOT commit them
backups/

# Arc process pid (used by arc restart)
.arc.pid

# Local migration overrides (if any)
arc.lock.local


# -----------------------------------------------------------------------------
# Editors / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini


# -----------------------------------------------------------------------------
# Docker / infra (committed when used, but local overrides are not)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.env.docker


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
tests/
subfiles/
hrms/
README.md


# -----------------------------------------------------------------------------
# What IS committed (for clarity)
# .env.example        ← template with variable names, no real values
# arc.toml            ← app config (no secrets — those go in .env)
# arc.lock            ← plugin registry
# pyproject.toml      ← dependencies
# backups/.gitkeep    ← keep the directory structure, not the files
# -----------------------------------------------------------------------------